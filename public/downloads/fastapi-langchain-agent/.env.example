# FastAPI + LangChain Agent Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the .env file — it is in .gitignore

# ── AI Keys ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=financial-agent
PINECONE_HOST=your-index-host.pinecone.io

# ── Security ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your-strong-secret-key-min-32-chars

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT=20/minute

# ── Redis Cache (optional) ─────────────────────────────────
# If not set, caching is disabled gracefully
REDIS_URL=redis://localhost:6379

# ── Monitoring ─────────────────────────────────────────────
# Get DSN from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── OpenAI Limits ──────────────────────────────────────────
MAX_TOKENS=1000
OPENAI_TIMEOUT=30

# ── Environment ────────────────────────────────────────────
ENVIRONMENT=production
